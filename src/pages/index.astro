---
import Layout from '../layouts/Layout.astro';
import HeroCard from '../components/HeroCard.astro';
import ArticleCard from '../components/ArticleCard.astro';
import LiveEventCard from '../components/LiveEventCard.astro';
import Newsletter from '../components/Newsletter.astro';
import { getCollection } from 'astro:content';

const allArticles = await getCollection('articles');
const articlesWithCollection = allArticles.map(a => ({ ...a, data: { ...a.data, collection: 'articles' } }));

const allLiveEvents = await getCollection('liveEvents');
const liveEventsWithCollection = allLiveEvents.map(a => ({ ...a, data: { ...a.data, collection: 'liveEvents' } }));

const activeLiveArticles = liveEventsWithCollection
  .filter(a => {
    if (a.data.isActive === false) return false;
    const eventTimeMs = a.data.date.valueOf();
    const isExpired = (Date.now() - eventTimeMs) > (12 * 60 * 60 * 1000);
    return !isExpired;
  })
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const activeIds = new Set(activeLiveArticles.map(a => a.id));
const inactiveLiveArticles = liveEventsWithCollection.filter(a => !activeIds.has(a.id));

const combinedLatest = [...articlesWithCollection, ...inactiveLiveArticles]
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

const featured = combinedLatest.find(a => a.data.featured) || combinedLatest[0];
const rest = combinedLatest.filter(a => a.id !== featured?.id);

const categories = [...new Set([...allArticles, ...allLiveEvents].map(a => a.data.category))];
---

<Layout>
  <main>
    {featured && (
      <section class="hero wrap" id="hero">
        <HeroCard article={featured.data} />
      </section>
    )}

    <section class="live-events-section" id="live-events">
      <div class="wrap">
        <div class="live-events-head">
          <div class="video-live-badge" style="margin-bottom:0;">
            <span class="live-dot"></span>
            LIVE
          </div>
          <h2>Live Events</h2>
        </div>
        
        {activeLiveArticles.length > 0 ? (
          <div class="live-events-grid">
            {activeLiveArticles.map(article => (
              <LiveEventCard article={article.data} />
            ))}
          </div>
        ) : (
          <div class="live-events-empty" style="text-align: center; padding: 40px 20px; background: rgba(255,255,255,0.02); border-radius: 8px; border: 1px solid rgba(255,255,255,0.05); margin-bottom: 2rem;">
            <p style="color: #888; font-size: 1.1rem; margin: 0;">There are currently no ongoing live events. Check back later!</p>
          </div>
        )}
      </div>
    </section>

    <section class="wrap">
      <div class="section-head" id="grid-head">
        <h2>Latest Stories</h2>
        <span class="count" id="story-count">{rest.length} {rest.length === 1 ? 'story' : 'stories'}</span>
      </div>
      
      <div class="filters" id="filters">
        <button class="chip active" data-cat="all">All Stories</button>
        {categories.map(c => (
          <button class="chip" data-cat={c}>{c}</button>
        ))}
      </div>
      
      <div class="grid" id="grid">
        {rest.map(article => (
          <div class="grid-item" data-cat={article.data.category}>
            <ArticleCard article={article.data} />
          </div>
        ))}
      </div>
    </section>

    <!-- <Newsletter variant="banner" /> -->
  </main>

  <script is:inline>
    // Client-side filtering logic
    document.addEventListener("DOMContentLoaded", () => {
      const filters = document.getElementById("filters");
      const grid = document.getElementById("grid");
      const countEl = document.getElementById("story-count");
      
      if (filters && grid) {
        filters.addEventListener("click", (e) => {
          const btn = e.target.closest(".chip");
          if (!btn) return;
          
          filters.querySelectorAll(".chip").forEach((c) => c.classList.remove("active"));
          btn.classList.add("active");
          
          const cat = btn.dataset.cat;
          const items = grid.querySelectorAll(".grid-item");
          let visibleCount = 0;
          
          items.forEach(item => {
            if (cat === "all" || item.dataset.cat === cat) {
              item.style.display = "block";
              visibleCount++;
            } else {
              item.style.display = "none";
            }
          });
          
          if (countEl) {
            countEl.textContent = `${visibleCount} ${visibleCount === 1 ? 'story' : 'stories'}`;
          }
        });
      }
    });
  </script>
</Layout>
