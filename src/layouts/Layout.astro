---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "Aviation Desk — Aviation Stories, Explained", 
  description = "Clear, well-reported stories on airlines, aircraft technology, incidents, and the industry behind them." 
} = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Inter:wght@400;500;600;700&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css" />

  <!-- MailerLite Webforms -->
  <script is:inline src="https://groot.mailerlite.com/js/w/webforms.min.js?v83147fa8ce2d95cb73ece7f28b469519" defer></script>
  <script is:inline>
    fetch("https://assets.mailerlite.com/jsonp/2511483/forms/193063203173827754/takel");
  </script>
</head>
<body>
  <Header />
  
  <slot />
  
  <Footer />

  <script is:inline>
    // Navigation toggle logic
    document.addEventListener("DOMContentLoaded", () => {
      const toggle = document.getElementById("navToggle");
      const nav = document.getElementById("mainNav");
      if (toggle && nav) {
        toggle.addEventListener("click", () => {
          nav.classList.toggle("open");
        });
      }
    });
  </script>
</body>
</html>
