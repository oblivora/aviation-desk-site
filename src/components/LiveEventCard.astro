---
export interface ArticleProps {
  id: string;
  slug: string;
  category: string;
  title: string;
  excerpt: string;
  date: string;
  readTime: string;
  image?: string;
  publisher?: string;
  publisherImage?: string;
}

const { article } = Astro.props as { article: ArticleProps };

const d = new Date(article.date);
const formattedDate = d.toLocaleDateString("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
});
---

<a href={`/articles/${article.slug}`} class="live-event-card">
  <div class="live-event-card__art">
    {article.image ? (
      <img src={article.image} alt={article.title} class="art" style="object-fit: cover; width: 100%; height: 100%;" />
    ) : (
      <div class="live-event-card__art-placeholder"></div>
    )}
    <div class="video-live-badge video-live-badge--card">
      <span class="live-dot"></span>
      LIVE
    </div>
  </div>
  <div class="live-event-card__content">
    <span class="eyebrow eyebrow--dark">{article.category}</span>
    <h3>
      <span class="headline-link flight-link flight-link--dark">
        {article.title}
        <span class="trace" aria-hidden="true">
          <svg viewBox="0 0 240 10" preserveAspectRatio="none">
            <path d="M2 6 L220 6"/>
            <g class="plane" transform="translate(216,6) rotate(0)">
              <path d="M0 -3 L9 0 L0 3 L2 0 Z" fill="var(--red)"/>
            </g>
          </svg>
        </span>
      </span>
    </h3>
    <p class="excerpt">{article.excerpt}</p>
    <div class="meta-line meta-line--dark">
      {article.publisher && (
        <div style="display: flex; align-items: center; gap: 6px;">
          {article.publisherImage && (
            <img src={article.publisherImage} alt={article.publisher} style="width: 20px; height: 20px; border-radius: 50%; object-fit: cover;" />
          )}
          <span>{article.publisher}</span>
          <span class="sep">·</span>
        </div>
      )}
      <div style="display: flex; align-items: center; gap: 6px;">
        <span>{formattedDate}</span>
        <span class="sep">·</span>
        <span>{article.readTime}</span>
      </div>
    </div>
  </div>
</a>
